# Evo Workspace Configuration
# Copy this file to .env and fill in your credentials

# Required: Path to the DUF file to convert
DUF_FILE_PATH=<your-duf-file-path>

# Required: Your Evo organization ID
EVO_ORG_ID=<your-org-id>

# Required: Your Evo workspace ID
EVO_WORKSPACE_ID=<your-workspace-id>

# Required: Your Evo client ID (service account)
EVO_CLIENT_ID=<your-client-id>

# Required: Your Evo client secret
EVO_CLIENT_SECRET=<your-client-secret>

# Required: Evo Hub URL
EVO_HUB_URL=<your-hub-url>

# Required: User agent (can be any string to identify your application)
EVO_USER_AGENT=<your-user-agent>
